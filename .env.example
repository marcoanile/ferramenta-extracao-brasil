# TOConline OAuth2 Credentials
# Obtenha em: Empresa > Configurações > Dados API
TOCONLINE_CLIENT_ID=your_client_id_here
TOCONLINE_CLIENT_SECRET=your_client_secret_here
TOCONLINE_OAUTH_URL=https://identity.toconline.pt
TOCONLINE_API_URL=https://apiv1.toconline.com

# Cegid Business (opcional)
CEGID_API_URL=
CEGID_API_KEY=

# App settings
SECRET_KEY=change_this_to_a_random_secret_key
# Local dev: ../data. On Render the blueprint sets this to /var/data (persistent disk).
DATA_DIR=../data
PORT=5000
DEBUG=false
